# Postgres
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=agentmolecule
DATABASE_URL=postgres://USER:PASS@postgres:5432/agentmolecule?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379

# Platform
PORT=8080
SECRETS_ENCRYPTION_KEY=        # 32-byte key (raw or base64). Leave empty for plaintext (dev only).
CONFIGS_DIR=                   # Path to workspace-configs-templates/ (auto-discovered if empty)
PLUGINS_DIR=                   # Path to plugins/ directory (default: /plugins in container)

# Canvas
NEXT_PUBLIC_PLATFORM_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Workspace Runtime
ANTHROPIC_API_KEY=
MODEL_PROVIDER=anthropic:claude-sonnet-4-6

# Langfuse (optional observability)
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
